{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/index.js" },
    { "source": "/uploads/(.*)", "destination": "backend/uploads/$1" },
    { "source": "/(.*)", "destination": "frontend/index.html" }
  ]
}
